pipeline {
    agent any

    environment {
        IMAGE_NAME = "node-app"
        CONTAINER_NAME = "myapp"
    }

    stages {

        stage('Build Image') {
            steps {
                sh 'docker build -t node-app:latest -f docker/Dockerfile .'
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                docker stop myapp || true
                docker rm myapp || true
                docker run -d -p 3000:3000 --name myapp node-app:latest
                '''
            }
        }

        stage('Health Check') {
            steps {
                sh '''
                sleep 5
                curl -f http://host.docker.internal:3000/health
                '''
            }
        }
    }

    post {
        success {
            sh 'docker tag node-app:latest node-app:stable'
            echo "✅ Deployment successful! Image tagged as node-app:stable"
        }

        failure {
            echo "❌ Deployment failed! Rolling back to stable version..."

            sh '''
            docker stop myapp || true
            docker rm myapp || true
            docker run -d -p 3000:3000 --name myapp node-app:stable
            '''

            echo "✅ Rollback complete! App restored to last stable version."
        }
    }
}